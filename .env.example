# ============================================================
# MedenPoche — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must NEVER be committed.
# In production (Vercel), set these in Project → Settings → Environment Variables.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Project URL + anon (public) key — Supabase dashboard → Settings → API.
# NEXT_PUBLIC_* values are exposed to the browser (this is expected for these two).
# Until NEXT_PUBLIC_SUPABASE_URL starts with "http", the app runs in a local
# no-Supabase mode (middleware skips auth) so you can boot before wiring it up.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service-role key — SERVER ONLY. Bypasses RLS; used for admin account deletion.
# NEVER prefix with NEXT_PUBLIC_ and never import it in a client component.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Google Gemini (AI tutor, MCQ extraction, embeddings) ────
# Server only. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Public site ─────────────────────────────────────────────
# Production domain — used for SEO canonical/OG URLs, sitemap.xml and robots.txt.
NEXT_PUBLIC_SITE_URL=https://medenpoche.ma

# WhatsApp number for upgrade / mentor-call / professor-session CTAs.
# International format, digits only, no "+" or spaces (e.g. 2126XXXXXXXX).
NEXT_PUBLIC_WHATSAPP_NUMBER=212600000000
